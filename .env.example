# ═══════════════════════════════════════════════════════════════
# FLOWTYM PMS — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ⚠️  NE JAMAIS committer .env sur GitHub
# ═══════════════════════════════════════════════════════════════

# ── SUPABASE ─────────────────────────────────────────────────
# Récupérer dans : Supabase → Settings → API
VITE_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
VITE_SUPABASE_KEY=VOTRE_CLE_ANON_PUBLIQUE

# ── STRIPE (optionnel — paiements en ligne) ──────────────────
# Récupérer dans : Stripe Dashboard → Developers → API Keys
VITE_STRIPE_PUBLIC_KEY=pk_live_VOTRE_CLE_PUBLIQUE_STRIPE

# ── APPLICATION ───────────────────────────────────────────────
VITE_APP_NAME=Flowtym PMS
VITE_APP_VERSION=5.0.0
VITE_APP_ENV=production

# ── PDP CONFORMITÉ FISCALE (optionnel) ───────────────────────
VITE_PDP_URL=https://pdp.chorus-pro-simulation.fr/api/v1
VITE_PDP_KEY=VOTRE_CLE_PDP
